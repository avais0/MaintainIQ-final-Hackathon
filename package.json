{
  "name": "maintainiq-root",
  "version": "1.0.0",
  "description": "Root orchestrator for MaintainIQ",
  "scripts": {
    "install-all": "npm install --prefix backend && npm install --prefix frontend",
    "start": "npm install --prefix backend && node backend/src/server.js",
    "dev": "start cmd.exe /k \"npm start --prefix backend\" && npm run dev --prefix frontend"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "qrcode": "^1.5.3",
    "sequelize": "^6.37.3",
    "sqlite3": "^5.1.7",
    "pg": "^8.11.5",
    "pg-hstore": "^2.3.4"
  }
}
